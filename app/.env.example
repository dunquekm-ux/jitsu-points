# Copy this file to .env.local and fill in your values.
# .env.local is gitignored — never commit real credentials.

# Cloudflare Worker URL for family sync.
# Local dev: run `wrangler dev` in /worker, then set this to http://localhost:8787
# Production: set to your deployed Worker URL (e.g. https://jitsu-api.<account>.workers.dev)
# Leave empty to run in local-only mode (no cloud sync, no write guards).
VITE_WORKER_URL=http://localhost:8787
